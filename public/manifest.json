{
  "manifest_version": 3,
  "name": "Clustr",
  "version": "1.3.5",
  "description": "A Chrome extension that allows users to create and manage clusters of bookmarks.",
  "icons": {
    "128": "./icons/icon128.png",
    "48": "./icons/icon48.png",
    "16": "./icons/icon16.png"
  },
  "chrome_url_overrides": {
    "newtab": "../index.html"
  },
  "permissions": ["bookmarks"]
}
