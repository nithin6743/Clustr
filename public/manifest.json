{
  "manifest_version": 3,
  "name": "Clustr",
  "version": "2.0",
  "description": "A Chrome extension that allows users to create and manage clusters of bookmarks.",
  "icons": {
    "128": "./icons/icon128.png",
    "32": "./icons/icon32.png",
    "16": "./icons/icon16.png"
  },
  "chrome_url_overrides": {
    "newtab": "/index.html"
  },
  "permissions": ["bookmarks", "storage"]
}
